<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
	<menu id="root-menu" label="Openbox 3">
		<item label="EAGLE">
			<action name="Execute">
				<execute>eagle</execute>
			</action>
		</item>
		<item label="Sublime">
			<action name="Execute">
				<execute>subl</execute>
			</action>
		</item>
		<item label="IDEA">
			<action name="Execute">
				<execute>idea</execute>
			</action>
		</item>
		<item label="File Manager">
			<action name="Execute">
				<execute>pcmanfm</execute>
			</action>
		</item>
		<item label="Chrome">
			<action name="Execute">
				<execute>google-chrome-stable</execute>
			</action>
		</item>
		<item label="VMWare">
			<action name="Execute">
				<execute>vmware</execute>
			</action>
		</item>
		<item label="Opera">
			<action name="Execute">
				<execute>opera-legacy</execute>
			</action>
		</item>
		<separator/>
		<item label="VirtualBox">
			<action name="Execute">
				<execute>virtualbox</execute>
			</action>
		</item>
		<item label="Xterm">
			<action name="Execute">
				<execute>xterm</execute>
			</action>
		</item>
		<item label="Gajim (Jabber)">
			<action name="Execute">
				<execute>gajim</execute>
			</action>
		</item>
		<item label="PulseAudio Control">
			<action name="Execute">
				<execute>pavucontrol</execute>
			</action>
		</item>
		<separator/>
		<item label="Log Out">
			<action name="Exit">
				<prompt>yes</prompt>
			</action>
		</item>
		<item label="Reconfigure Openbox">
			<action name="Reconfigure"/>
		</item>
		<separator/>
		<item label="Reboot">
			<action name="Execute">
				<execute>systemctl reboot</execute>
			</action>
		</item>
		<item label="Shutdown">
			<action name="Execute">
				<execute>systemctl poweroff</execute>
			</action>
		</item>
	</menu>
</openbox_menu>
